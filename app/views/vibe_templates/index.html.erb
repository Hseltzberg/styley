<h1>
  List of all vibes
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new vibe
    </h2>
  </header>

  <form action="/insert_vibe" method="post">
    <div>
      <label for="outfit_id_box">
        Outfit
      </label>

      <input type="text" id="outfit_id_box" name="query_outfit_id">
    </div>

    <div>
      <label for="feeling_id_box">
        Feeling
      </label>

      <input type="text" id="feeling_id_box" name="query_feeling_id">
    </div>

    <button type="submit">
      Create vibe
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_vibes.each do |a_vibe| %>
      <li>
        <a href="/vibes/<%= a_vibe.id %>">
          Vibe #<%= a_vibe.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
