<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4">Edit Profile</h2>

      <%= form_for(resource, { :as => resource_name, :url => registration_path(resource_name), :html => { :method => :put } }) do |f| %>
        <%= render("devise/shared/error_messages", { :resource => resource }) %>

        <div class="mb-3">
          <label for="email_field" class="form-label">Email</label>
          <%= f.email_field(:email, { :autofocus => true, :autocomplete => "email", :class => "form-control", :id => "email_field" }) %>
        </div>

        <div class="mb-3">
          <label for="username_field" class="form-label">Username</label>
          <%= f.text_field(:username, { :class => "form-control", :id => "username_field" }) %>
        </div>

        <div class="mb-3">
          <label for="password_field" class="form-label">New password</label>
          <%= f.password_field(:password, { :autocomplete => "new-password", :class => "form-control", :id => "password_field" }) %>
        </div>

        <div class="mb-3">
          <label for="password_confirmation_field" class="form-label">Password confirmation</label>
          <%= f.password_field(:password_confirmation, { :autocomplete => "new-password", :class => "form-control", :id => "password_confirmation_field" }) %>
        </div>

        <div class="mb-3">
          <label for="current_password_field" class="form-label">Current password</label>
          <%= f.password_field(:current_password, { :autocomplete => "current-password", :class => "form-control", :id => "current_password_field" }) %>
        </div>

        <div class="d-grid">
          <%= f.submit("Update account", { :class => "btn btn-dark" }) %>
        </div>
      <% end %>
    </div>
  </div>
</div>
