<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <h2 class="mb-4">Log in</h2>

      <%= form_for(resource, { :as => resource_name, :url => session_path(resource_name) }) do |f| %>
        <div class="mb-3">
          <label for="email_field" class="form-label">Email</label>
          <%= f.email_field(:email, { :autofocus => true, :autocomplete => "email", :class => "form-control", :id => "email_field" }) %>
        </div>

        <div class="mb-3">
          <label for="password_field" class="form-label">Password</label>
          <%= f.password_field(:password, { :autocomplete => "current-password", :class => "form-control", :id => "password_field" }) %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-check mb-3">
            <%= f.check_box(:remember_me, { :class => "form-check-input", :id => "remember_me_field" }) %>
            <label for="remember_me_field" class="form-check-label">Remember me</label>
          </div>
        <% end %>

        <div class="d-grid">
          <%= f.submit("Log in", { :class => "btn btn-dark" }) %>
        </div>
      <% end %>

      <div class="mt-3">
        <%= render("devise/shared/links") %>
      </div>
    </div>
  </div>
</div>
