<h1>
  List of all outfit seasons
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new outfit season
    </h2>
  </header>

  <form action="/insert_outfit_season" method="post">
    <div>
      <label for="outfit_id_box">
        Outfit
      </label>

      <input type="text" id="outfit_id_box" name="query_outfit_id">
    </div>

    <div>
      <label for="season_id_box">
        Season
      </label>

      <input type="text" id="season_id_box" name="query_season_id">
    </div>

    <button type="submit">
      Create outfit season
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_outfit_seasons.each do |an_outfit_season| %>
      <li>
        <a href="/outfit_seasons/<%= an_outfit_season.id %>">
          Outfit season #<%= an_outfit_season.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
