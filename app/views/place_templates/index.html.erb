<h1>
  List of all places
</h1>

<hr>

<article>
  <header>
    <h2>
      Add a new place
    </h2>
  </header>

  <form action="/insert_place" method="post">
    <div>
      <label for="outfit_id_box">
        Outfit
      </label>

      <input type="text" id="outfit_id_box" name="query_outfit_id">
    </div>

    <div>
      <label for="occasion_id_box">
        Occasion
      </label>

      <input type="text" id="occasion_id_box" name="query_occasion_id">
    </div>

    <button type="submit">
      Create place
    </button>
  </form>
</article>

<hr>

<article>
  <ul>
    <% @list_of_places.each do |a_place| %>
      <li>
        <a href="/places/<%= a_place.id %>">
          Place #<%= a_place.id %>
        </a>
      </li>
    <% end %>
  </ul>
</article>

<hr>
