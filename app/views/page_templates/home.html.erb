<% if current_user.present? %>
  <h1>✨hey <strong><%= current_user.username.presence || current_user.email %></strong>, let's get dressed ✨</h1>

  <div><a href="/outfits">my closet ☞</a></div>
  <div><a href="/outfits/new">add new fit</a></div>

  <% @list_of_public_outfits.each do |an_outfit| %>
    <% matching_users = User.where({ :id => an_outfit.user_id }) %>
    <% the_user = matching_users.at(0) %>

    <p><strong><%= the_user.username %></strong></p>
    <p><%= an_outfit.note_headline %></p>
    <img src="<%= an_outfit.outfit_photo %>">
  <% end %>

<% else %>
  <h1> ⭐️👗 welcome to Styley 👗⭐️ </h1>
  <h2> you are probably here because you don't know what to wear— or at leaast you *think* you don't know. let's have some fun. 🥳 </h2>
  <p>new here? <a href="/users/sign_up">sign up</a> to start building your closet.</p>

    <p> back for more? <a href="/users/sign_in">sign in</a> to pick up where you left off</p>
<% end %>
