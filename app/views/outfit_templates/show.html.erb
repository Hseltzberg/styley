<p>
  <a href="/outfits">☜ Back to my closet</a>
</p>

<h1>Outfit details</h1>

<img src="<%= @the_outfit.outfit_photo %>" style="width: 200px; height: 200px; object-fit: cover; border-radius: 12px;">
<h2><%= @the_outfit.note_headline %></h2>

<p>
  📝note to self: <%= @the_outfit.note_details %>
</p>

<p>
  Feelings:
</p>

<ul>
  <% @the_outfit.feelings.each do |a_feeling| %>
    <li><%= a_feeling.name %></li>
  <% end %>
</ul>

<p>
  Occasions:
</p>

<ul>
  <% @the_outfit.occasions.each do |an_occasion| %>
    <li><%= an_occasion.name %></li>
  <% end %>
</ul>

<p>
  Seasons:
</p>

<ul>
  <% @the_outfit.seasons.each do |a_season| %>
    <li><%= a_season.name %></li>
  <% end %>
</ul>

<p>
  Visibility:
</p>

<ul>
  <% if @the_outfit.is_public %>
   <li> public</li>
  <% else %>
    <li> private</li>
  <% end %>
</ul>

<p>
  <a href="/outfits/<%= @the_outfit.id %>/edit">
    Edit this outfit
  </a>
</p>

<form action="/delete_outfit/<%= @the_outfit.id %>" method="post">
  <button>Delete this outfit</button>
</form>
